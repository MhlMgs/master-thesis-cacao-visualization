      <bpmn:text>DATA: commands=manual:record escalation decision in the case system, in_args=ioc_value, confidence_score,
      notification_status, out_args=case_summary, variables=ticket_datatype, final_status
ROLE: agent=SOC Tier 2; type=group; targets=Messaging Business Unit; type=organization, Phishing;
      type=security-category; category=phishing</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:association id="Association_0891d6272cff4dc186ee2063b1dd4c6f" sourceRef="Task_action_document_escalation" targetRef="TextAnnotation_2195ae8d8e384ef089f9b12fc7caaf61" />
    <bpmn:textAnnotation id="TextAnnotation_f4a0811b7a264dd8b83cdad3495eaffb">
      <bpmn:text>DATA: commands=manual:create low-priority observation note, in_args=ioc_value,
      confidence_score, out_args=case_summary, variables=final_status
ROLE: agent=SOC Tier 2; type=group; targets=mail-gateway-01; type=linux-system</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:association id="Association_649037340e114e11962132176a37087c" sourceRef="Task_action_record_low_priority" targetRef="TextAnnotation_f4a0811b7a264dd8b83cdad3495eaffb" />
    <bpmn:textAnnotation id="TextAnnotation_8ac1a7bed1324306906693138797268e">
      <bpmn:text>DATA: commands=manual:record failed enrichment request and assign man...,
      in_args=ioc_value, ioc_type, out_args=case_summary, variables=final_status,
      authentication=Threat API Basic Auth [http-basic] (username=ti-reader)
ROLE: agent=SOC Tier 2; type=group; targets=External Threat Feed API;
      type=http-api, mail-gateway-01; type=linux-system</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:association id="Association_296d9b7587684690ab1506044fa5811e" sourceRef="Task_action_record_enrichment_failure" targetRef="TextAnnotation_8ac1a7bed1324306906693138797268e" />
    <bpmn:textAnnotation id="TextAnnotation_626ed53b0fae4f6ab585ed7a84b5e573">
      <bpmn:text>META: delay=PT0S; timeout=PT30S; markings=marking-definition--tlp-green
DATA: variables=decision_basis
