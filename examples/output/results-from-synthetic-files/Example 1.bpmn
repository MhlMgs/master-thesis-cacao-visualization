<?xml version='1.0' encoding='utf-8'?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:cacao="https://example.org/cacao-bpmn/extensions" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="Definitions_6417c749-2f0e-4b5e-873e-3a09485a9576" targetNamespace="https://example.org/cacao-bpmn">
  <bpmn:process id="Process_playbook_11111111-2222-4333-8444-555555555555" name="Extended Incident Response Demonstration" isExecutable="false">
    <bpmn:extensionElements>
      <cacao:property name="playbook_id" value="playbook--11111111-2222-4333-8444-555555555555" />
      <cacao:property name="spec_version" value="cacao-2.0" />
      <cacao:property name="playbook_types" value="[&quot;investigation&quot;, &quot;mitigation&quot;, &quot;notification&quot;]" />
      <cacao:property name="playbook_activities" value="[&quot;identify&quot;, &quot;analyze&quot;, &quot;contain&quot;, &quot;notify&quot;]" />
      <cacao:property name="playbook_processing_summary" value="[&quot;Investigate suspicious host activity&quot;, &quot;Contain compromised assets&quot;, &quot;Notify stakeholders and preserve evidence&quot;]" />
      <cacao:property name="workflow_start" value="start--01" />
      <cacao:property name="created" value="2026-04-20T09:00:00Z" />
      <cacao:property name="modified" value="2026-04-20T09:30:00Z" />
      <cacao:property name="created_by" value="identity--aaaaaaaa-bbbb-4ccc-8ddd-eeeeeeeeeeee" />
      <cacao:property name="valid_from" value="2026-04-20T00:00:00Z" />
      <cacao:property name="valid_until" value="2027-04-20T00:00:00Z" />
      <cacao:property name="revoked" value="false" />
      <cacao:property name="derived_from" value="[&quot;playbook--00000000-1111-4222-8333-444444444444&quot;]" />
      <cacao:property name="labels" value="[&quot;synthetic&quot;, &quot;incident-response&quot;, &quot;demo&quot;]" />
      <cacao:property name="markings" value="[&quot;marking-definition--tlp-amber&quot;]" />
      <cacao:property name="industry_sectors" value="[&quot;information-technology&quot;, &quot;public-sector&quot;]" />
    </bpmn:extensionElements>
    <bpmn:startEvent id="StartEvent_start_01" name="Suspicious Alert Received">
      <bpmn:documentation>Start the incident handling workflow.</bpmn:documentation>
      <bpmn:extensionElements>
        <cacao:property name="cacao_step_id" value="start--01" />
        <cacao:property name="cacao_step_type" value="start" />
      </bpmn:extensionElements>
    </bpmn:startEvent>
    <bpmn:task id="Task_action_triage" name="Initial Triage">
      <bpmn:documentation>Validate the alert and enrich context.</bpmn:documentation>
      <bpmn:extensionElements>
        <cacao:property name="cacao_step_id" value="action--triage" />
        <cacao:property name="cacao_step_type" value="action" />
        <cacao:property name="delay" value="PT5M" />
        <cacao:property name="timeout" value="PT30M" />
        <cacao:property name="in_args" value="[&quot;alert_id&quot;, &quot;host_identifier&quot;, &quot;severity&quot;]" />
        <cacao:property name="out_args" value="[&quot;triage_status&quot;, &quot;evidence_bundle&quot;]" />
        <cacao:property name="step_variables" value="[&quot;triage_status&quot;, &quot;evidence_collected&quot;]" />
        <cacao:property name="markings" value="[&quot;marking-definition--tlp-amber&quot;]" />
        <cacao:property name="step_extensions" value="[&quot;host-risk-score&quot;]" />
        <cacao:property name="agent" value="group--soc-team" />
        <cacao:property name="targets" value="[&quot;linux--app-server-01&quot;, &quot;security-category--endpoint&quot;]" />
      </bpmn:extensionElements>
    </bpmn:task>
    <bpmn:exclusiveGateway id="Gateway_if_condition_escalate" name="Escalate Incident?">
      <bpmn:documentation>Check whether the incident requires coordinated response.</bpmn:documentation>
      <bpmn:extensionElements>
        <cacao:property name="cacao_step_id" value="if-condition--escalate" />
        <cacao:property name="cacao_step_type" value="if-condition" />
      </bpmn:extensionElements>
    </bpmn:exclusiveGateway>
    <bpmn:exclusiveGateway id="Gateway_switch_condition_response_mode" name="Select Response Mode">
      <bpmn:documentation>Choose the containment strategy.</bpmn:documentation>
      <bpmn:extensionElements>
        <cacao:property name="cacao_step_id" value="switch-condition--response-mode" />
        <cacao:property name="cacao_step_type" value="switch-condition" />
      </bpmn:extensionElements>
    </bpmn:exclusiveGateway>
    <bpmn:task id="Task_action_collect_evidence" name="Collect Evidence">
      <bpmn:documentation>Acquire forensic data before containment.</bpmn:documentation>
      <bpmn:extensionElements>
        <cacao:property name="cacao_step_id" value="action--collect-evidence" />
        <cacao:property name="cacao_step_type" value="action" />
        <cacao:property name="agent" value="group--soc-team" />
        <cacao:property name="targets" value="[&quot;linux--app-server-01&quot;]" />
      </bpmn:extensionElements>
    </bpmn:task>
    <bpmn:exclusiveGateway id="Gateway_while_condition_containment_loop" name="Containment Needed?">
      <bpmn:documentation>Loop until containment is confirmed.</bpmn:documentation>
      <bpmn:extensionElements>
        <cacao:property name="cacao_step_id" value="while-condition--containment-loop" />
        <cacao:property name="cacao_step_type" value="while-condition" />
      </bpmn:extensionElements>
    </bpmn:exclusiveGateway>
    <bpmn:task id="Task_action_contain_host" name="Contain Host via OpenC2">
      <bpmn:documentation>Issue a containment command to the endpoint control platform.</bpmn:documentation>
      <bpmn:extensionElements>
        <cacao:property name="cacao_step_id" value="action--contain-host" />
        <cacao:property name="cacao_step_type" value="action" />
        <cacao:property name="in_args" value="[&quot;host_identifier&quot;, &quot;containment_scope&quot;]" />
        <cacao:property name="out_args" value="[&quot;containment_result&quot;]" />
        <cacao:property name="agent" value="security-category--containment" />
        <cacao:property name="targets" value="[&quot;http-api--containment&quot;, &quot;linux--app-server-01&quot;]" />
      </bpmn:extensionElements>
    </bpmn:task>
    <bpmn:sequenceFlow id="Flow_9dc662d14d814ac7b954865db578696a" sourceRef="Task_action_contain_host" targetRef="Gateway_while_condition_containment_loop" name="Success" />
    <bpmn:endEvent id="EndEvent_end_workflow_exception" name="Workflow Exception">
      <bpmn:extensionElements>
        <cacao:property name="cacao_step_id" value="end--workflow-exception" />
        <cacao:property name="cacao_step_type" value="end" />
      </bpmn:extensionElements>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_a49b4b8b22e049a5be38f28996d3f733" sourceRef="Task_action_contain_host" targetRef="EndEvent_end_workflow_exception" name="Failure" />
    <bpmn:sequenceFlow id="Flow_8f94b4af568244caa50708dd3d13e2c4" sourceRef="Gateway_while_condition_containment_loop" targetRef="Task_action_contain_host" name="True" />
    <bpmn:parallelGateway id="Gateway_parallel_post_containment" name="Post-Containment Activities">
      <bpmn:documentation>Run technical and communication activities in parallel.</bpmn:documentation>
      <bpmn:extensionElements>
        <cacao:property name="cacao_step_id" value="parallel--post-containment" />
        <cacao:property name="cacao_step_type" value="parallel" />
      </bpmn:extensionElements>
    </bpmn:parallelGateway>
    <bpmn:task id="Task_action_update_record" name="Update Incident Record">
      <bpmn:documentation>Update the case record after containment has been completed.</bpmn:documentation>
      <bpmn:extensionElements>
        <cacao:property name="cacao_step_id" value="action--update-record" />
        <cacao:property name="cacao_step_type" value="action" />
        <cacao:property name="agent" value="organization--it-ops" />
        <cacao:property name="targets" value="[&quot;sector--public&quot;]" />
      </bpmn:extensionElements>
    </bpmn:task>
    <bpmn:task id="Task_action_final_review" name="Final Review">
      <bpmn:documentation>Confirm closure conditions and summarize the response.</bpmn:documentation>
      <bpmn:extensionElements>
        <cacao:property name="cacao_step_id" value="action--final-review" />
        <cacao:property name="cacao_step_type" value="action" />
        <cacao:property name="agent" value="group--soc-team" />
        <cacao:property name="targets" value="[&quot;linux--app-server-01&quot;]" />
      </bpmn:extensionElements>
    </bpmn:task>
    <bpmn:task id="Task_action_close_case" name="Close Case">
      <bpmn:documentation>Close the playbook run and archive relevant data.</bpmn:documentation>
