        <cacao:property name="cacao_step_id" value="end--complete" />
        <cacao:property name="cacao_step_type" value="end" />
      </bpmn:extensionElements>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_86ec059b35f1493a81e6e5d7b1c2c162" sourceRef="Task_action_close_case" targetRef="EndEvent_end_complete" />
