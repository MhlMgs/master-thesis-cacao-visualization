<?xml version='1.0' encoding='utf-8'?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:cacao="https://example.org/cacao-bpmn/extensions" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="Definitions_463d8cd3-9b66-4eb0-8904-02171a26041a" targetNamespace="https://example.org/cacao-bpmn">
  <bpmn:process id="Process_playbook_3c4d5e6f-1111-4222-8333-1234567890ab" name="Phishing Investigation and Remediation Demonstration" isExecutable="false">
    <bpmn:extensionElements>
      <cacao:property name="playbook_id" value="playbook--3c4d5e6f-1111-4222-8333-1234567890ab" />
      <cacao:property name="spec_version" value="2.0" />
      <cacao:property name="playbook_types" value="[&quot;investigation&quot;, &quot;remediation&quot;, &quot;notification&quot;]" />
      <cacao:property name="playbook_activities" value="[&quot;analyze-collected-data&quot;, &quot;restrict-access&quot;, &quot;notify&quot;]" />
      <cacao:property name="playbook_processing_summary" value="Combines analyst review, automated account restriction and stakeholder notification." />
      <cacao:property name="workflow_start" value="start--phishing" />
      <cacao:property name="created" value="2025-04-24T09:00:00Z" />
      <cacao:property name="modified" value="2025-04-24T09:00:00Z" />
      <cacao:property name="created_by" value="identity--9b8f4e12-aaaa-4b56-9c12-abcdefabcdef" />
      <cacao:property name="valid_from" value="2025-04-24T09:00:00Z" />
      <cacao:property name="valid_until" value="2026-04-24T09:00:00Z" />
      <cacao:property name="revoked" value="false" />
      <cacao:property name="derived_from" value="[&quot;playbook--legacy-phishing-investigation-demo&quot;]" />
      <cacao:property name="labels" value="[&quot;synthetic&quot;, &quot;phishing&quot;, &quot;validation-demo&quot;]" />
      <cacao:property name="markings" value="[&quot;marking-definition--tlp-green-demo&quot;]" />
      <cacao:property name="industry_sectors" value="[&quot;finance&quot;, &quot;government&quot;]" />
    </bpmn:extensionElements>
    <bpmn:startEvent id="StartEvent_start_phishing" name="Start Investigation">
      <bpmn:documentation>Begin handling of a reported phishing email.</bpmn:documentation>
      <bpmn:extensionElements>
        <cacao:property name="cacao_step_id" value="start--phishing" />
        <cacao:property name="cacao_step_type" value="start" />
      </bpmn:extensionElements>
    </bpmn:startEvent>
    <bpmn:task id="Task_action_review_alert" name="Review Reported Alert">
      <bpmn:documentation>Analyst reviews the reported message and initial enrichment context.</bpmn:documentation>
      <bpmn:extensionElements>
        <cacao:property name="cacao_step_id" value="action--review-alert" />
        <cacao:property name="cacao_step_type" value="action" />
        <cacao:property name="delay" value="PT5M" />
        <cacao:property name="timeout" value="PT20M" />
        <cacao:property name="in_args" value="[&quot;reported_message_id&quot;, &quot;reporting_user&quot;]" />
        <cacao:property name="out_args" value="[&quot;message_headers&quot;, &quot;mailbox_user&quot;, &quot;phishing_score&quot;]" />
        <cacao:property name="step_variables" value="[&quot;triage_status&quot;]" />
        <cacao:property name="markings" value="[&quot;marking-definition--tlp-green-demo&quot;]" />
        <cacao:property name="agent" value="group--soc-tier2" />
        <cacao:property name="targets" value="[&quot;http-api--email-archive&quot;, &quot;linux--mail-analysis-host&quot;]" />
      </bpmn:extensionElements>
    </bpmn:task>
    <bpmn:exclusiveGateway id="Gateway_if_credible" name="Phishing Credible?">
      <bpmn:documentation>Determine whether the reported email should be treated as a phishing incident.</bpmn:documentation>
      <bpmn:extensionElements>
        <cacao:property name="cacao_step_id" value="if--credible" />
        <cacao:property name="cacao_step_type" value="if-condition" />
      </bpmn:extensionElements>
    </bpmn:exclusiveGateway>
    <bpmn:parallelGateway id="Gateway_parallel_response" name="Immediate Response Activities">
      <bpmn:documentation>Perform automated restriction and evidence collection in parallel.</bpmn:documentation>
      <bpmn:extensionElements>
        <cacao:property name="cacao_step_id" value="parallel--response" />
        <cacao:property name="cacao_step_type" value="parallel" />
      </bpmn:extensionElements>
    </bpmn:parallelGateway>
    <bpmn:task id="Task_action_disable_account" name="Disable Account via OpenC2">
      <bpmn:documentation>Use the SOAR platform to suspend the impacted mailbox account.</bpmn:documentation>
      <bpmn:extensionElements>
        <cacao:property name="cacao_step_id" value="action--disable-account" />
        <cacao:property name="cacao_step_type" value="action" />
        <cacao:property name="in_args" value="[&quot;mailbox_user&quot;]" />
        <cacao:property name="out_args" value="[&quot;account_status=disabled&quot;]" />
        <cacao:property name="step_variables" value="[&quot;notification_required&quot;]" />
        <cacao:property name="agent" value="http-api--soar" />
        <cacao:property name="targets" value="[&quot;security-category--credential-theft&quot;]" />
      </bpmn:extensionElements>
    </bpmn:task>
    <bpmn:task id="Task_action_document_response" name="Document Immediate Response">
      <bpmn:documentation>Record the first response actions in the case system.</bpmn:documentation>
      <bpmn:extensionElements>
        <cacao:property name="cacao_step_id" value="action--document-response" />
        <cacao:property name="cacao_step_type" value="action" />
        <cacao:property name="out_args" value="[&quot;case_status=contained&quot;]" />
        <cacao:property name="agent" value="organization--security-ops" />
        <cacao:property name="targets" value="[&quot;security-category--phishing&quot;]" />
      </bpmn:extensionElements>
    </bpmn:task>
    <bpmn:exclusiveGateway id="Gateway_switch_escalation" name="Select Additional Escalation Path">
      <bpmn:documentation>Choose the next path based on confidence and communication needs.</bpmn:documentation>
      <bpmn:extensionElements>
        <cacao:property name="cacao_step_id" value="switch--escalation" />
        <cacao:property name="cacao_step_type" value="switch-condition" />
      </bpmn:extensionElements>
    </bpmn:exclusiveGateway>
    <bpmn:task id="Task_playbook_action_notify_stakeholders" name="Call Stakeholder Notification Playbook">
      <bpmn:documentation>Invoke a separate notification playbook for business stakeholders.</bpmn:documentation>
      <bpmn:extensionElements>
        <cacao:property name="cacao_step_id" value="playbook-action--notify-stakeholders" />
        <cacao:property name="cacao_step_type" value="playbook-action" />
        <cacao:property name="in_args" value="[&quot;mailbox_user&quot;, &quot;artifact_bundle&quot;]" />
        <cacao:property name="out_args" value="[&quot;notification_status=sent&quot;]" />
        <cacao:property name="agent" value="organization--security-ops" />
        <cacao:property name="targets" value="[&quot;organization--hr&quot;]" />
        <cacao:property name="playbook_id" value="playbook--stakeholder-notification-demo" />
        <cacao:property name="playbook_version" value="1.0" />
      </bpmn:extensionElements>
    </bpmn:task>
    <bpmn:task id="Task_action_close_contained" name="Close Contained Case">
      <bpmn:documentation>Finalize the phishing case after remediation and communication steps.</bpmn:documentation>
      <bpmn:extensionElements>
        <cacao:property name="cacao_step_id" value="action--close-contained" />
        <cacao:property name="cacao_step_type" value="action" />
        <cacao:property name="out_args" value="[&quot;case_status=closed_contained&quot;]" />
        <cacao:property name="agent" value="organization--security-ops" />
        <cacao:property name="targets" value="[&quot;security-category--phishing&quot;]" />
      </bpmn:extensionElements>
    </bpmn:task>
    <bpmn:endEvent id="EndEvent_end_closed" name="Case Closed">
      <bpmn:documentation>The phishing case has been finalized.</bpmn:documentation>
      <bpmn:extensionElements>
        <cacao:property name="cacao_step_id" value="end--closed" />
        <cacao:property name="cacao_step_type" value="end" />
      </bpmn:extensionElements>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_f5633e5165c046a8ab7a6771ffaab108" sourceRef="Task_action_close_contained" targetRef="EndEvent_end_closed" />
    <bpmn:sequenceFlow id="Flow_106a30228131418ba7d5ef8434c65167" sourceRef="Task_playbook_action_notify_stakeholders" targetRef="Task_action_close_contained" />
    <bpmn:sequenceFlow id="Flow_176753e6d73747f482eb21aa385a3a01" sourceRef="Gateway_switch_escalation" targetRef="Task_playbook_action_notify_stakeholders" name="high-confidence" />
    <bpmn:task id="Task_action_manual_review" name="Escalate to Manual Review">
      <bpmn:documentation>Escalate the case to deeper analyst review and scope assessment.</bpmn:documentation>
      <bpmn:extensionElements>
        <cacao:property name="cacao_step_id" value="action--manual-review" />
        <cacao:property name="cacao_step_type" value="action" />
        <cacao:property name="timeout" value="PT45M" />
        <cacao:property name="agent" value="group--soc-tier2" />
        <cacao:property name="targets" value="[&quot;security-category--credential-theft&quot;]" />
      </bpmn:extensionElements>
    </bpmn:task>
    <bpmn:sequenceFlow id="Flow_929614e0e59546d994bea1a049388ee0" sourceRef="Task_action_manual_review" targetRef="Task_action_close_contained" />
    <bpmn:sequenceFlow id="Flow_9bb20adb31b04a20bb1d075e14ddde82" sourceRef="Gateway_switch_escalation" targetRef="Task_action_manual_review" name="requires-hunting" />
    <bpmn:sequenceFlow id="Flow_243461809e054b76931d0c49dec195b1" sourceRef="Gateway_switch_escalation" targetRef="Task_action_close_contained" name="Default" />
    <bpmn:sequenceFlow id="Flow_6fbba45af7a549d48243cba511d7b22b" sourceRef="Task_action_document_response" targetRef="Gateway_switch_escalation" />
    <bpmn:endEvent id="EndEvent_end_exception" name="Workflow Exception End">
      <bpmn:documentation>Used when automated restriction or enrichment cannot be completed.</bpmn:documentation>
      <bpmn:extensionElements>
        <cacao:property name="cacao_step_id" value="end--exception" />
        <cacao:property name="cacao_step_type" value="end" />
      </bpmn:extensionElements>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_9c539366f5094f0d97a73c6ba2c830ed" sourceRef="Task_action_disable_account" targetRef="EndEvent_end_exception" name="Failure" />
    <bpmn:sequenceFlow id="Flow_739b301349514fd0a01c215fc9569462" sourceRef="Gateway_parallel_response" targetRef="Task_action_disable_account" />
    <bpmn:task id="Task_action_collect_artifacts" name="Collect Mailbox Artifacts">
      <bpmn:documentation>Collect headers, attachments and URLs for later review.</bpmn:documentation>
      <bpmn:extensionElements>
        <cacao:property name="cacao_step_id" value="action--collect-artifacts" />
        <cacao:property name="cacao_step_type" value="action" />
        <cacao:property name="in_args" value="[&quot;reported_message_id&quot;]" />
        <cacao:property name="out_args" value="[&quot;artifact_bundle&quot;, &quot;contains_malicious_link&quot;]" />
        <cacao:property name="step_variables" value="[&quot;artifact_status&quot;]" />
        <cacao:property name="agent" value="software--mail-gateway" />
        <cacao:property name="targets" value="[&quot;linux--mail-analysis-host&quot;]" />
      </bpmn:extensionElements>
    </bpmn:task>
    <bpmn:sequenceFlow id="Flow_be26f1a569cb4a4c9698e492fa3eb25a" sourceRef="Gateway_parallel_response" targetRef="Task_action_collect_artifacts" />
    <bpmn:sequenceFlow id="Flow_42dabdffed914e1792926501acb851c7" sourceRef="Gateway_if_credible" targetRef="Gateway_parallel_response" name="True" />
    <bpmn:task id="Task_action_record_benign" name="Record Benign Outcome">
      <bpmn:documentation>Document the alert as benign and retain the enrichment result.</bpmn:documentation>
      <bpmn:extensionElements>
        <cacao:property name="cacao_step_id" value="action--record-benign" />
        <cacao:property name="cacao_step_type" value="action" />
        <cacao:property name="out_args" value="[&quot;case_status=benign_closed&quot;]" />
        <cacao:property name="agent" value="organization--security-ops" />
        <cacao:property name="targets" value="[&quot;security-category--credential-theft&quot;]" />
      </bpmn:extensionElements>
    </bpmn:task>
    <bpmn:sequenceFlow id="Flow_7071432c36864722b0d869669701fc2a" sourceRef="Task_action_record_benign" targetRef="EndEvent_end_closed" />
    <bpmn:sequenceFlow id="Flow_fe24b5606cf547b096740cc9ead3b81b" sourceRef="Gateway_if_credible" targetRef="Task_action_record_benign" name="False" />
    <bpmn:sequenceFlow id="Flow_fc4e2ff6f26246678f2b585bfc689955" sourceRef="Task_action_review_alert" targetRef="Gateway_if_credible" />
    <bpmn:sequenceFlow id="Flow_19442b5ecf6a4d4e9aff8cf20e160a83" sourceRef="StartEvent_start_phishing" targetRef="Task_action_review_alert" />
    <bpmn:parallelGateway id="GatewayJoin_parallel_response">
      <bpmn:documentation>Synthetic join gateway for parallel step Immediate Response Activities. Perform automated restriction and evidence collection in parallel.</bpmn:documentation>
      <bpmn:extensionElements>
        <cacao:property name="synthetic_for_step" value="parallel--response" />
        <cacao:property name="synthetic_for_type" value="parallel" />
        <cacao:property name="synthetic_kind" value="parallel_join" />
      </bpmn:extensionElements>
    </bpmn:parallelGateway>
    <bpmn:sequenceFlow id="Flow_5441e0788bcf4beab9d3a21463fd1d9a" sourceRef="Task_action_collect_artifacts" targetRef="GatewayJoin_parallel_response" />
    <bpmn:sequenceFlow id="Flow_483ef949ed6245849cb9adb77f71e1df" sourceRef="Task_action_disable_account" targetRef="GatewayJoin_parallel_response" />
