    <bpmn:textAnnotation id="TextAnnotation_04913682fa984645b80af576a8fb5680">
      <bpmn:text>DATA: commands=bash:WPProtect
ROLE: agent=Adversary Group; type=group; targets=LockyBart; type=software</bpmn:text>
    </bpmn:textAnnotation>
