    <bpmn:textAnnotation id="TextAnnotation_e4bf27de0aba466a955ffc69ba380e4d">
      <bpmn:text>META: id=playbook--fefb9f12-d308-461c-8aa7-a5d6279ab468; name=LockyBart ransomware;
      description=This playbook captures the sequence of steps of how encrypts files to
      obtain a ransom using the LockyBart ransomware.
