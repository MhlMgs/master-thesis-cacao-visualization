ROLE: agent=Adversary Group; type=group; targets=Endpoint with
      ransomware; type=security-category; category=endpoint</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:association id="Association_67f457d76b374b70869ede18181ca1a0" sourceRef="Task_action_3fdb51db_2548_4beb_ab7d_f52b3ab1e5ed" targetRef="TextAnnotation_fe34431b752846ee8d15d4e42dfb5d96" />
    <bpmn:textAnnotation id="TextAnnotation_0c1bc146121b42a28b8439475fade41d">
      <bpmn:text>DATA: commands=bash:vssadmin.exe delete shadows /all /quiet
ROLE: agent=LockyBart; type=software</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:association id="Association_2d243a28b21b4c87992095463b17b4a8" sourceRef="Task_action_7953f6e2_5f09_4fe3_8ffd_476ec5dabe3c" targetRef="TextAnnotation_0c1bc146121b42a28b8439475fade41d" />
