      "category": [
        "credential-access"
      ]
    }
  },
  "target_definitions": {
    "http-api--threatfeed": {
      "type": "http-api",
      "name": "External Threat Feed API",
      "description": "Threat intelligence HTTP API.",
      "authentication_info": [
        "auth-info--http-basic"
      ]
    },
    "linux--mail-gateway": {
      "type": "linux-system",
      "name": "mail-gateway-01",
      "description": "Linux email gateway tied to the IOC."
    },
    "organization--biz-unit": {
      "type": "organization",
      "name": "Messaging Business Unit",
      "description": "Business unit owning the affected asset."
    },
    "security-category--phishing": {
      "type": "security-category",
      "name": "Phishing",
      "description": "Security category linked to the IOC.",
      "category": [
        "phishing"
      ]
    }
  },
  "workflow_start": "start--ti-enrichment",
  "workflow_exception": "end--workflow-exception",
  "workflow": {
    "start--ti-enrichment": {
      "type": "start",
      "name": "Start Enrichment",
      "description": "Entry point for indicator enrichment.",
      "on_completion": "action--query-threat-api"
    },
    "action--query-threat-api": {
      "type": "action",
      "name": "Query Threat API",
      "description": "Query an external threat intelligence source.",
      "delay": "PT5S",
      "timeout": "PT2M",
      "step_variables": {
        "api_request_id": "req-445",
        "request_datatype": "identifier"
      },
      "in_args": [
        "ioc_value",
        "ioc_type",
        "tlp_default"
      ],
      "out_args": [
        "confidence_score",
        "matched_campaign",
        "recommended_channel"
      ],
      "markings": [
        "marking-definition--tlp-green"
      ],
      "step_extensions": {
        "triage_score": {
          "extension_definition": "extension-definition--triage-score",
          "value": 73
        }
      },
      "commands": [
        {
          "type": "http-api",
          "method": "GET",
          "endpoint": "/v1/indicator/lookup",
          "command": "GET /v1/indicator/lookup?value=${ioc_value}&type=${ioc_type}",
          "authentication_info": [
            "auth-info--http-basic"
          ]
        }
      ],
      "agent": "group--soc-tier2",
      "targets": [
        "http-api--threatfeed",
        "linux--mail-gateway",
        "security-category--phishing"
      ],
      "on_success": "if-condition--requires-escalation",
      "on_failure": "action--record-enrichment-failure"
    },
    "if-condition--requires-escalation": {
      "type": "if-condition",
      "name": "Escalation Required?",
      "description": "Check whether the enrichment result requires escalation.",
      "condition": "${confidence_score >= 70 || escalation_required == true}",
      "delay": "PT0S",
      "timeout": "PT30S",
      "step_variables": {
        "decision_basis": "score-policy"
      },
      "markings": [
        "marking-definition--tlp-green"
      ],
      "on_true": "playbook-action--notify-cert",
      "on_false": "action--record-low-priority"
    },
    "playbook-action--notify-cert": {
      "type": "playbook-action",
      "name": "Call Escalation Notification Playbook",
      "description": "Trigger a notification playbook for the CERT and affected business unit.",
      "in_args": [
        "ioc_value",
        "confidence_score",
        "preferred_channel"
      ],
      "out_args": [
        "notification_status"
      ],
      "step_variables": {
        "notify_mode": "internal"
      },
      "commands": [
        {
          "type": "workflow-trigger",
          "command": "trigger escalation-notification-playbook",
          "authentication_info": [
            "auth-info--oauth2"
          ]
        }
      ],
      "agent": "organization--cert",
      "targets": [
        "organization--biz-unit"
      ],
      "playbook_id": "playbook--notify-0001",
      "playbook_version": "1.2",
      "on_completion": "action--document-escalation"
    },
    "action--document-escalation": {
      "type": "action",
      "name": "Document Escalation Decision",
      "description": "Document who was notified and why escalation was required.",
      "step_variables": {
        "ticket_datatype": "identifier",
        "final_status": "escalated"
      },
      "in_args": [
        "ioc_value",
        "confidence_score",
        "notification_status"
      ],
      "out_args": [
        "case_summary"
      ],
      "commands": [
        {
          "type": "manual",
          "command": "record escalation decision in the case system"
        }
      ],
      "agent": "group--soc-tier2",
      "targets": [
        "organization--biz-unit",
        "security-category--phishing"
      ],
      "on_completion": "end--completed"
    },
    "action--record-low-priority": {
      "type": "action",
      "name": "Record Low Priority Finding",
      "description": "Document the finding as monitored and not escalated.",
      "step_variables": {
        "final_status": "monitored"
      },
      "in_args": [
        "ioc_value",
        "confidence_score"
      ],
      "out_args": [
        "case_summary"
      ],
      "commands": [
        {
          "type": "manual",
          "command": "create low-priority observation note"
        }
      ],
      "agent": "group--soc-tier2",
      "targets": [
        "linux--mail-gateway"
      ],
      "on_completion": "end--completed"
    },
    "end--completed": {
      "type": "end",
      "name": "Close Enrichment Case",
      "description": "Normal end of the enrichment and triage process."
    },
    "end--workflow-exception": {
      "type": "end",
      "name": "Workflow Exception",
      "description": "Fallback end point for unrecoverable enrichment issues."
    },
    "action--record-enrichment-failure": {
      "type": "action",
      "name": "Record Enrichment Failure",
      "description": "Document that the enrichment request failed and hand the case to manual review.",
      "step_variables": {
        "final_status": "enrichment-failed"
      },
      "in_args": [
        "ioc_value",
        "ioc_type"
      ],
      "out_args": [
        "case_summary"
      ],
      "commands": [
        {
          "type": "manual",
          "command": "record failed enrichment request and assign manual review"
        }
      ],
      "agent": "group--soc-tier2",
      "targets": [
        "http-api--threatfeed",
        "linux--mail-gateway"
      ],
      "on_completion": "end--workflow-exception"
    }
  }
}